# Copy to `.env` for local API (never commit `.env`). The API loads it via dotenv (`server.js`).
# After filling SMTP_*, run: npm run email:test
# On Vercel: Project → Settings → Environment Variables (same names; no .env file).

# --- Email: Gmail (use an App Password, not your normal Gmail password) ---
# 1. Google Account → Security → 2-Step Verification ON
# 2. Security → App passwords → create "Mail" → copy the 16-character password
# 3. Fill SMTP_USER / SMTP_PASS / SMTP_FROM with your Gmail address
SMTP_SERVICE=gmail
SMTP_USER=youraddress@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM=youraddress@gmail.com

# --- Email: other SMTP (omit SMTP_SERVICE=gmail and use these instead) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com

# --- Database (production) ---
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# --- Local dev only (file-backed store; not for production) ---
# ALLOW_LOCAL_STORE=1
